{
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" } },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "DownloadQueueTopic": "download-queue",
    "DownloadStateTopic": "download-state"
  },
  "DownloadStateRebuild": {
    "BootstrapServers": "localhost:9092",
    "StateTopic": "download-state",
    "GroupId": "dispatcher-download-state-rebuild",
    "IdleTimeoutSeconds": 5
  },
  "KafkaConsumer": {
    "BootstrapServers": "localhost:9092",
    "ProgressTopic": "download-progress",
    "GroupId": "dispatcher-progress"
  },
  "AgentHeartbeat": {
    "BootstrapServers": "localhost:9092",
    "HeartbeatTopic": "agent-heartbeat",
    "GroupId": "dispatcher-agents"
  }
}
