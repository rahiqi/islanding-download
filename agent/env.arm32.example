# Copy to .env when deploying the agent on Raspberry Pi 32-bit (e.g. in Portainer stack).
# Ensures the stack uses DockerfileRaspberryPi2 and platform linux/arm/v7.

AGENT_PLATFORM=linux/arm/v7
AGENT_DOCKERFILE=RaspberryPi2

# Required (set your values)
DISPATCHER_URL=http://your-dispatcher:8084
KAFKA_BOOTSTRAP_SERVERS=your-kafka-host:9092

# Optional
AGENT_NAME=my-pi-agent
AGENT_LOCATION=home
# Local file serving: base URL for "Download from agent" link (e.g. http://192.168.1.10:8080)
# AGENT_LOCAL_URL=http://192.168.1.10:8080
