# Build context: repository root
# Example:
# docker buildx build --platform linux/arm/v7 -f agent/downloader-agent/DockerfileRaspberryPi2 .

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS base
USER root
WORKDIR /app
EXPOSE 8080
EXPOSE 8081

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
ARG BUILD_CONFIGURATION=Release
WORKDIR /src
COPY ["agent/downloader-agent/downloader-agent.csproj", "agent/downloader-agent/"]
RUN dotnet restore "./agent/downloader-agent/downloader-agent.csproj"
COPY . .
WORKDIR "/src/agent/downloader-agent"
RUN dotnet publish "./downloader-agent.csproj" -c $BUILD_CONFIGURATION -o /app/publish /p:UseAppHost=false

FROM base AS final
RUN apt-get update && apt-get install -y --no-install-recommends gosu && rm -rf /var/lib/apt/lists/*
WORKDIR /app

# App binaries
COPY --from=build /app/publish .

# Prebuilt Kafka binaries provided in the build context root
COPY Confluent.Kafka.dll /app/Confluent.Kafka.dll
COPY librdkafka.so /app/librdkafka.so
COPY librdkafka.so.1 /app/librdkafka.so.1

COPY agent/downloader-agent/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENV LD_LIBRARY_PATH=/app
ENTRYPOINT ["/entrypoint.sh"]
CMD ["dotnet", "downloader-agent.dll"]
